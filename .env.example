# App
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://admin:password@localhost:27020,localhost:27021,localhost:27022/drukshopify?replicaSet=rs0&authSource=admin
MONGO_DB_NAME=drukshopify

# Redis
REDIS_HOST=localhost
